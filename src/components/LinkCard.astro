---
interface Props {
  href: string;
  title: string;
  label?: string;
  featured?: boolean;
}

const { href, title, label, featured = false } = Astro.props;
---

<a
  href={href}
  class:list={["btn", { "featured-btn": featured }]}
  target="_blank"
  rel="noreferrer"
>
  <span>{title}</span>
  {label && <span class="btn-label">{label}</span>}
</a>

<style>
  .btn {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.2rem;
    width: 100%;
    padding: 18px 24px;
    overflow: hidden;
    border: 1px solid var(--card-border);
    border-radius: 16px;
    background: var(--card-bg);
    text-decoration: none;
    font-size: 18px;
    font-weight: 600;
    backdrop-filter: blur(10px);
    transition:
      transform 0.3s cubic-bezier(0.25, 0.8, 0.25, 1),
      border-color 0.3s ease,
      background 0.3s ease,
      box-shadow 0.3s ease;
  }

  .btn::before {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(45deg, transparent, rgba(219, 154, 0, 0.1), transparent);
    transform: translateX(-100%);
    transition: transform 0.6s;
  }

  .btn:hover::before,
  .btn:focus-visible::before {
    transform: translateX(100%);
  }

  .btn:hover,
  .btn:focus-visible {
    border-color: var(--primary);
    background: rgba(255, 255, 255, 0.1);
    box-shadow: var(--shadow), 0 0 15px rgba(219, 154, 0, 0.2);
    transform: translateY(-4px);
    outline: none;
  }

  .featured-btn {
    background: linear-gradient(135deg, rgba(219, 154, 0, 0.2), rgba(219, 154, 0, 0.05));
    border-color: rgba(219, 154, 0, 0.3);
  }

  .featured-btn:hover,
  .featured-btn:focus-visible {
    background: linear-gradient(135deg, rgba(219, 154, 0, 0.3), rgba(219, 154, 0, 0.1));
  }

  .btn-label {
    margin-top: 4px;
    color: var(--primary);
    font-size: 12px;
    font-weight: 400;
    letter-spacing: 1px;
    text-transform: uppercase;
  }
</style>
