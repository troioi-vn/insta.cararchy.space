---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Catarchy - links",
  description = "Welcome to the Catarchy space."
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;800&display=swap"
      rel="stylesheet"
    />
    <script
      defer
      src="https://umami.meo-mai-moi.com/script.js"
      data-website-id="a5a9de82-8268-41f6-97d4-132d28532b87"
    ></script>
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  :root {
    --bg-color: #0f0f13;
    --text-color: #ffffff;
    --muted-text: #a0a0a0;
    --primary: #db9a00;
    --primary-hover: #ffb81c;
    --card-bg: rgba(255, 255, 255, 0.05);
    --card-border: rgba(255, 255, 255, 0.1);
    --shadow: 0 10px 20px rgba(0, 0, 0, 0.3);
  }

  * {
    box-sizing: border-box;
  }

  html {
    color-scheme: dark;
  }

  body {
    font-family: "Poppins", sans-serif;
    margin: 0;
    min-height: 100vh;
    color: var(--text-color);
    background-color: var(--bg-color);
    background-image:
      radial-gradient(circle at 50% 0%, #2a1f00 0%, transparent 50%),
      linear-gradient(180deg, rgba(255, 184, 28, 0.08), transparent 35%);
  }

  a {
    color: inherit;
  }
</style>
